# Configuración de transcriptor — plantilla (sin valores sensibles).
# Copiar a .env y ajustar. El .env real está gitignored.

# --- Servidor web local ---
TRANSCRIPTOR_HOST=127.0.0.1
TRANSCRIPTOR_PORT=8731

# --- Motor de transcripción ---
# Modelo: tiny | base | small | medium | large-v3
WHISPER_MODEL=large-v3
# Dispositivo: cuda (GPU) | cpu | auto (intenta cuda, cae a cpu)
WHISPER_DEVICE=auto
# Tipo de cómputo: float16 (gpu) | int8 (cpu) | int8_float16
WHISPER_COMPUTE_TYPE=float16
# Idioma por defecto (es) o vacío para autodetectar
WHISPER_LANGUAGE=es

# --- Carpeta raíz sugerida para guardar transcripciones ---
# La UI permite elegir/crear otra; esta es solo el punto de partida.
SALIDA_BASE=C:\CODIGO\transcripciones
